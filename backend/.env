# ==========================================
# 1. 系统基础配置
# ==========================================
NODE_ENV=dev
PORT=8000
FRONTEND_URL=http://localhost:3000

# ==========================================
# 2. 数据库配置
# ==========================================

# --- [当前使用] 本地 PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=123456
DB_NAME=blog_db
DB_SYNC=true

# --- [生产预留] Supabase Database ---
# 提示：从 Supabase 项目设置 -> Database 获取以下信息
# SUPABASE_DB_HOST=db.your-project-id.supabase.co
# SUPABASE_DB_PORT=5432
# SUPABASE_DB_USER=postgres
# SUPABASE_DB_PASS=你的超级管理员密码
# SUPABASE_DB_NAME=blog_db

# ==========================================
# 3. supabase 服务化预留(api & storage)
# ==========================================
# 用于 UploadService 切换到云存储
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_KEY=your-anon-or-service-role-key
# SUPABASE_BUCKET_NAME=blog-uploads
# 提示：从 Supabase 项目设置 -> API 获取 SUPABASE_URL 和 SUPABASE_KEY

# ==========================================
# 4. 邮箱配置(malihog)
# ==========================================
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USER=MailHog_User
MAIL_PASS=MailHog_Pass
MAIL_SECURE=false
MAIL_FROM="Dev Blog <nobody@duckblog.com>"

# ==========================================
# 5. 安全与存储配置
# ==========================================
JWT_SECRET=2400496518c05571026c4f7b31758407a122130297f0881e59777132345de7a8
JWT_EXPIRES_IN=7d

# 本地文件存储路径（开发环境使用）
UPLOAD_DIR=uploads
